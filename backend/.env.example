# === 本地 Ollama + Qwen（推荐）===
# 先: ollama serve
# 已有模型: qwen3:8b （本机已检测到）
USE_LLM=true
LLM_API_KEY=ollama
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen3:8b

# 若只想 Mock 不调模型:
# USE_LLM=false

# 持久化
SESSION_STORE=sqlite
# SQLITE_PATH=

# LangGraph 检查点
USE_GRAPH_CHECKPOINTER=true
# GRAPH_CHECKPOINT_PATH=

# 云端示例（可选）:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
